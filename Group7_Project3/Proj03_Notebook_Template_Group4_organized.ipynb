      "87           0.86  \n",
      "88           0.86  \n",
      "89           0.86  \n",
      "84           0.84  \n",
      "85           0.84  \n",
      "418          0.80  \n",
      "419          0.80  \n",
      "128          0.80  \n",
      "129          0.80  \n",
      "Best model parameters:\n",
      "{'vector_size': 50, 'window': 10, 'sg': 1, 'epochs': 20, 'C': 1, 'class_weight': None}\n"
     ]
