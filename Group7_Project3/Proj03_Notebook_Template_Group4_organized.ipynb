   ],
   "source": [
    "from gensim.models import Word2Vec\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import accuracy_score, recall_score\n",
    "\n",
    "def get_post_embedding(tokens, model):\n",
    "    word_vectors = []\n",
    "    \n",
    "    for token in tokens:\n",
    "        if token in model.wv:\n",
    "            word_vectors.append(model.wv[token])\n",
    "    \n",
    "    if len(word_vectors) == 0:\n",
    "        return np.zeros(model.vector_size)\n",
    "    \n",
    "    return np.sum(word_vectors, axis=0)\n",
    "\n",
    "best_recall = -1\n",
    "best_model = None\n",
    "\n",
    "vector_sizes = [50, 100, 200]\n",
    "windows = [5, 10, 15]\n",
    "sg_values = [0, 1]\n",
    "epochs_list = [10, 15, 20, 30]\n",
    "\n",
    "C_values = [0.1, 1, 10]\n",
    "class_weights = [None, \"balanced\"]\n",
    "\n",
    "results = []\n",
    "\n",
    "for vs in vector_sizes:\n",
    "    for w in windows:\n",
    "        for sg in sg_values:\n",
    "            for ep in epochs_list:\n",
    "\n",
    "                # Train Word2Vec\n",
    "                w2v = Word2Vec(\n",
    "                    sentences=X_train_w2v,\n",
    "                    vector_size=vs,\n",
    "                    window=w,\n",
    "                    min_count=1,\n",
    "                    sg=sg,\n",
    "                    epochs=ep,\n",
    "                    workers=4,\n",
    "                    seed=42\n",
    "                )\n",
    "\n",
    "                # Convert to embeddings\n",
    "                X_train_vec_w2v = np.array([get_post_embedding(t, w2v) for t in X_train_w2v])\n",
    "                X_test_vec_w2v  = np.array([get_post_embedding(t, w2v) for t in X_test_w2v])\n",
    "\n",
    "                for C in C_values:\n",
    "                    for cw in class_weights:\n",
    "\n",
    "                        lr = LogisticRegression(\n",
    "                            C=C,\n",
    "                            class_weight=cw,\n",
    "                            max_iter=1000,\n",
    "                            random_state=42\n",
    "                        )\n",
    "\n",
    "                        lr.fit(X_train_vec_w2v, y_train_w2v)\n",
    "                        pred_w2v = lr.predict(X_test_vec_w2v)\n",
    "\n",
    "                        acc = accuracy_score(y_test_w2v, pred_w2v)\n",
    "                        recall = recall_score(y_test_w2v, pred_w2v, pos_label=1)\n",
    "\n",
    "                        results.append({\n",
    "                            \"vector_size\": vs,\n",
    "                            \"window\": w,\n",
    "                            \"sg\": sg,\n",
    "                            \"epochs\": ep,\n",
    "                            \"C\": C,\n",
    "                            \"class_weight\": cw,\n",
    "                            \"accuracy\": acc,\n",
    "                            \"toxic_recall\": recall\n",
    "                        })\n",
    "\n",
    "                        # select best model by toxic recall\n",
    "                        if recall > best_recall:\n",
    "                            best_recall = recall\n",
    "                            best_model = {\n",
    "                                \"w2v\": w2v,\n",
    "                                \"lr\": lr,\n",
    "                                \"y_pred\": pred_w2v,\n",
    "                                \"params\": {\n",
    "                                    \"vector_size\": vs,\n",
    "                                    \"window\": w,\n",
    "                                    \"sg\": sg,\n",
    "                                    \"epochs\": ep,\n",
    "                                    \"C\": C,\n",
    "                                    \"class_weight\": cw\n",
    "                                }\n",
    "                            }\n",
    "\n",
    "# results dataframe\n",
    "results_df = pd.DataFrame(results)\n",
    "results_df = results_df.sort_values(\n",
    "    by=[\"toxic_recall\", \"accuracy\"],\n",
    "    ascending=False\n",
    ")\n",
    "\n",
    "print(results_df.head(10))\n",
    "print(\"Best model parameters:\")\n",
    "print(best_model[\"params\"])\n",
    "\n",
    "best_pred_w2v = best_model[\"y_pred\"]"
   ]
  },
